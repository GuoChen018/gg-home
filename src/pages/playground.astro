---
import MainLayout from '../layouts/MainLayout.astro';

---

<MainLayout title="Playground" description='My Playground' thumbnail="/images/og-img.jpg">
    <main class="playground">
        <ul class="playground-grid">
            <!-- Example items - replace with your actual prototypes -->
            <!-- Use <video> for videos or <img> for images -->
            <li class="playground-item">
                <a href="/playground/shadow-over-border">
                    <div class="playground-media">
                        <img src="/images/playground/button.png" alt="Shadow instead of border prototype">
                        <div class="playground-info">
                            <span class="playground-name">Shadow instead of border</span>
                            <span class="playground-date">2025</span>
                        </div>
                    </div>
                </a>
            </li>
            <!-- Add more items here -->
            <!-- Example with image and dark text (for light images): -->
            <!--
            <li class="playground-item">
                <a href="/playground/item-name">
                    <div class="playground-media">
                        <img src="/images/your-image.jpg" alt="Item description">
                        <div class="playground-info">
                            <span class="playground-name">Item Name</span>
                            <span class="playground-date">Date</span>
                        </div>
                    </div>
                </a>
            </li>
            -->
            <!-- Example with video: -->
            <!--
            <li class="playground-item">
                <a href="/playground/item-name">
                    <div class="playground-media">
                        <video class="playground-video" muted autoplay loop src="/video/video.mp4"></video>
                        <div class="playground-info">
                            <span class="playground-name">Item Name</span>
                            <span class="playground-date">Date</span>
                        </div>
                    </div>
                </a>
            </li>
            -->
        </ul>
    </main>
</MainLayout>

