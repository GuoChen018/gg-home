---
import MainLayout from '../layouts/MainLayout.astro';

---

<MainLayout title="Playground" description='My Playground' thumbnail="/images/og-img.jpg">
    <main class="playground">
        <ul class="playground-grid">
            <li class="playground-item">
                <div class="playground-card playground-card-linked">
                    <div class="playground-info">
                        <span class="playground-name">Inner Shadow Card</span>
                        <span class="playground-date">2026</span>
                    </div>
                    <div class="playground-media">
                        <img src="/images/playground/inset-input.png" alt="Inner Shadow Card prototype" width="1024" height="548">
                    </div>
                    <a href="/playground/inset-input" class="playground-view">View</a>
                </div>
            </li>
            <li class="playground-item">
                <div class="playground-card playground-card-linked">
                    <div class="playground-info">
                        <span class="playground-name">Oak Onboarding</span>
                        <span class="playground-date">2026</span>
                    </div>
                    <div class="playground-media">
                        <video class="playground-video" muted autoplay loop playsinline preload="metadata" src="/video/oak-onboarding.mp4" width="2712" height="2160"></video>
                    </div>
                    <a href="https://www.oakfocus.co/" target="_blank" rel="noopener noreferrer" class="playground-view">View</a>
                </div>
            </li>
            <li class="playground-item">
                <div class="playground-card">
                    <div class="playground-info">
                        <span class="playground-name">Button States</span>
                        <span class="playground-date">2026</span>
                    </div>
                    <div class="playground-media">
                        <video class="playground-video" muted autoplay loop playsinline preload="metadata" src="/video/oak-button-states.mp4" width="3840" height="1724"></video>
                    </div>
                </div>
            </li>
            <li class="playground-item">
                <div class="playground-card">
                    <div class="playground-info">
                        <span class="playground-name">Loader</span>
                        <span class="playground-date">2026</span>
                    </div>
                    <div class="playground-media">
                        <video class="playground-video" muted autoplay loop playsinline preload="metadata" src="/video/loader.mp4" width="3836" height="2160"></video>
                    </div>
                </div>
            </li>
            <li class="playground-item">
                <div class="playground-card">
                    <div class="playground-info">
                        <span class="playground-name">Chat Input</span>
                        <span class="playground-date">2026</span>
                    </div>
                    <div class="playground-media">
                        <video class="playground-video" muted autoplay loop playsinline preload="metadata" src="/video/chat-input.mp4" width="3452" height="2160"></video>
                    </div>
                </div>
            </li>
            <li class="playground-item">
                <div class="playground-card">
                    <div class="playground-info">
                        <span class="playground-name">AI Guidance</span>
                        <span class="playground-date">2026</span>
                    </div>
                    <div class="playground-media">
                        <video class="playground-video" muted autoplay loop playsinline preload="metadata" src="/video/blender-workflow.mp4" width="3308" height="2160"></video>
                    </div>
                </div>
            </li>
            <li class="playground-item">
                <div class="playground-card playground-card-linked">
                    <div class="playground-info">
                        <span class="playground-name">Shadow instead of border</span>
                        <span class="playground-date">2025</span>
                    </div>
                    <div class="playground-media">
                        <img src="/images/playground/button.png" alt="Shadow instead of border prototype" loading="lazy" width="2256" height="632">
                    </div>
                    <a href="/playground/shadow-over-border" class="playground-view">View</a>
                </div>
            </li>
        </ul>
    </main>
</MainLayout>

<script>
    function initPlayground() {
        const grid = document.querySelector('.playground-grid') as HTMLElement;
        if (!grid) return;

        function layoutMasonry() {
            const items = Array.from(grid.querySelectorAll('.playground-item')) as HTMLElement[];
            if (!items.length) return;

            const gap = 8;
            const gridWidth = grid.clientWidth;
            let cols = 3;
            if (gridWidth <= 540) cols = 1;
            else if (gridWidth <= 800) cols = 2;

            const colWidth = (gridWidth - gap * (cols - 1)) / cols;
            const colHeights = new Array(cols).fill(0);

            items.forEach(item => {
                item.style.width = `${colWidth}px`;
                item.style.position = 'absolute';

                const shortest = colHeights.indexOf(Math.min(...colHeights));
                const x = shortest * (colWidth + gap);
                const y = colHeights[shortest];

                item.style.left = `${x}px`;
                item.style.top = `${y}px`;

                colHeights[shortest] += item.offsetHeight + gap;
            });

            grid.style.height = `${Math.max(...colHeights)}px`;
        }

        layoutMasonry();
        grid.classList.add('ready');
        window.addEventListener('resize', layoutMasonry);

        document.querySelectorAll('.playground-media img, .playground-media video').forEach(el => {
            const onLoaded = () => {
                el.classList.add('loaded');
                layoutMasonry();
            };

            if (el instanceof HTMLVideoElement) {
                if (el.readyState >= 2) onLoaded();
                else el.addEventListener('loadeddata', onLoaded, { once: true });
            } else if (el instanceof HTMLImageElement) {
                if (el.complete && el.naturalHeight > 0) onLoaded();
                else el.addEventListener('load', onLoaded, { once: true });
            }
        });

        document.querySelectorAll('.playground-card-linked').forEach(card => {
            card.addEventListener('click', (e) => {
                if ((e.target as HTMLElement).closest('a')) return;
                const link = card.querySelector('.playground-view') as HTMLElement | null;
                if (link) link.click();
            });
        });
    }

    document.addEventListener('astro:page-load', initPlayground);
</script>

